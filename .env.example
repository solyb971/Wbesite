# ===========================================
# SolYB CRM - Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your actual values

# ===========================================
# SUPABASE Configuration
# ===========================================
# Get these from: https://supabase.com > Your Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===========================================
# BREVO (Email Service)
# ===========================================
# Get this from: https://app.brevo.com > Account > SMTP & API
BREVO_API_KEY=your_brevo_api_key_here

# Secret partagé pour protéger le webhook Brevo.
# Configure l'URL côté Brevo avec ?token=CE_SECRET
# Génère-le avec: openssl rand -hex 32
BREVO_WEBHOOK_SECRET=your_random_webhook_secret_here

# Expéditeur des emails — DOIT être un expéditeur validé dans Brevo.
# Tant que le domaine solyb.fr n'est pas authentifié, utiliser une adresse validée
# (ex: solyb971@gmail.com). Une fois le domaine validé: contact@solyb.fr
BREVO_SENDER_EMAIL=solyb971@gmail.com
BREVO_SENDER_NAME=SolYB - Yacine Bouhassoun

# ===========================================
# CRON JOB SECURITY
# ===========================================
# Generate a random secret for cron job authentication
# Example: openssl rand -hex 32
CRON_SECRET=your_random_secret_here_minimum_32_characters

# ===========================================
# URL PUBLIQUE DE L'APPLICATION
# ===========================================
# Utilisée notamment pour le lien de réinitialisation de mot de passe.
# En local: http://localhost:3000 — en prod: https://solyb.fr
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# CRISP (Chat en direct)
# ===========================================
# Website ID depuis Crisp > Settings > Website Settings
NEXT_PUBLIC_CRISP_WEBSITE_ID=your_crisp_website_id_here

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development

# ===========================================
# OPTIONAL: Development Mode
# ===========================================
# Set to "true" to use mock data without Supabase/Brevo (for local development)
# NEXT_PUBLIC_USE_MOCK=false

# ===========================================
# OPTIONAL: Admin Email
# ===========================================
# Email address to receive admin alerts (notifications de nouveaux leads)
ADMIN_EMAIL=solyb971@gmail.com
