# ===========================================
# SolYB CRM - Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your actual values

# ===========================================
# SUPABASE Configuration
# ===========================================
# Get these from: https://supabase.com > Your Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===========================================
# BREVO (Email Service)
# ===========================================
# Get this from: https://app.brevo.com > Account > SMTP & API
BREVO_API_KEY=your_brevo_api_key_here

# ===========================================
# CRON JOB SECURITY
# ===========================================
# Generate a random secret for cron job authentication
# Example: openssl rand -hex 32
CRON_SECRET=your_random_secret_here_minimum_32_characters

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development

# ===========================================
# OPTIONAL: Development Mode
# ===========================================
# Set to "true" to use mock data without Supabase/Brevo (for local development)
# NEXT_PUBLIC_USE_MOCK=false

# ===========================================
# OPTIONAL: Admin Email
# ===========================================
# Email address to receive admin alerts
ADMIN_EMAIL=admin@solyb.gp
